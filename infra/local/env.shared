# Shared local dev config — safe to commit.
# All values target LocalStack / local environment only.
# Actual secrets are seeded via infra/local/localstack/init/01-init-secretsmanager.sh
#
# For go run (outside Docker), use AWS_ENDPOINT=http://localhost:4566 instead.
ENV=local
LOG_LEVEL=debug
AWS_REGION=us-east-2
AWS_ENDPOINT=http://localstack:4566
AWS_SECRET_PREFIX=komodo/local/
AWS_SECRET_BATCH=all-secrets
