{
  "name": "komodo-desktop-svelte",
  "version": "1.0.0",
  "private": true,
  "description": "Modern ecommerce website",
  "homepage": "./",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "build:demo": "vite build --mode mock",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "up": "bun update --latest",
    "clean": "bunx rimraf .svelte-kit dist build node_modules",
    "fresh": "bun run clean && bun install --linker=isolated",
    "latest": "bun update --latest",
    "gen:types": "bun run scripts/gen-types.ts",
    "preinstall": "npx only-allow bun",
    "prepare": "svelte-kit sync"
  },
  "dependencies": {
    "@sveltejs/kit": "2.57.1",
    "@tailwindcss/vite": "^4.1.18",
    "@threlte/core": "8.5.7",
    "@threlte/extras": "9.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-redact": "^3.5.0",
    "gsap": "^3.14.2",
    "isomorphic-dompurify": "3.7.1",
    "komodo-forge-sdk-ts": "github:rdevitto86/komodo-forge-sdk-ts",
    "lenis": "1.3.21",
    "lucide-svelte": "1.0.1",
    "nanoid": "^5.1.6",
    "postprocessing": "^6.38.2",
    "svelte": "^5.55.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "0.183.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/fast-redact": "^3.0.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.3.0",
    "jsdom": "29.0.2",
    "minimatch": "10.2.5",
    "openapi-typescript": "^7.13.0",
    "svelte-check": "^4.4.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "7.3.2",
    "vitest": "^4.1.3"
  },
  "resolutions": {
    "flatted": "^3.4.2"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "packageManager": "bun@1.2.4",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.2.0"
  }
}
